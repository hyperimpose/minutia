{erl_opts, [debug_info]}.
{deps, [{bencode,   {git, "https://github.com/hyperimpose/bencode.git",   {branch, "master"}}},
        {polycache, {git, "https://github.com/hyperimpose/polycache.git", {branch, "master"}}}]}.

{pre_hooks, [{"(linux|darwin|solaris)",   compile, "make -C \"$REBAR_ROOT_DIR\""},
             {"(freebsd|netbsd|openbsd)", compile, "gmake -C \"$REBAR_ROOT_DIR\""},
             {"(linux|darwin|solaris)",   clean, "make -C \"$REBAR_ROOT_DIR\" clean"},
             {"(freebsd|netbsd|openbsd)", clean, "gmake -C \"$REBAR_ROOT_DIR\" clean"}]}.

{shell, [{apps, [bencode, polycache, minutia]}]}.
